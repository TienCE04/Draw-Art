<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp">


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintDimensionRatio="176:244"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


    </com.google.android.material.card.MaterialCardView>

    <!--    dung glide bo goc-->


    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/imgThumb"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="10dp"
        android:elevation="4dp"
        android:scaleType="centerInside"
        app:layout_constraintDimensionRatio="152:152"
        app:layout_constraintEnd_toEndOf="@+id/cvBg"
        app:layout_constraintStart_toStartOf="@+id/cvBg"
        app:layout_constraintTop_toTopOf="@+id/cvBg"
        tools:src="@drawable/img_thumb_temp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:elevation="4dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@+id/cvBg"
        app:layout_constraintEnd_toEndOf="@+id/cvBg"
        app:layout_constraintStart_toStartOf="@+id/cvBg">

        <TextView
            android:id="@+id/tvName"
            style="@style/BodyNormalM1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="Hello" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                style="@style/BodyNormalM1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/msg_level" />

            <TextView
                android:id="@+id/tvLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvNumberFrame"
            style="@style/BodySmallR1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/neutral_500"
            tools:text="10 frames" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>